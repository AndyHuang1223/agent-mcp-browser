{
  "name": "agent-mcp-browser",
  "version": "1.0.0",
  "description": "OpenAI Agents SDK + Playwright MCP browser automation agent",
  "type": "module",
  "scripts": {
    "dev": "tsx src/main.ts",
    "start": "tsx src/main.ts",
    "typecheck": "tsc --noEmit",
    "mcp:server": "pnpm run mcp:server:headless",
    "mcp:server:headless": "npx -y @playwright/mcp@latest --port 8931 --headless",
    "mcp:server:attach": "dotenv -e .env -- npx -y @playwright/mcp@latest --port 8931 --extension --browser chrome",
    "task:product-search": "tsx src/main.ts -- --template product-search",
    "task:product-search:demo": "tsx src/main.ts -- --template product-search --query \"iPhone 16 128GB\" --locale \"台灣（繁體中文）\" --max-results 8 --allow-open-product-page",
    "task:product-search:precheckout-demo": "tsx src/main.ts -- --template product-search --query \"Dyson 吸塵器\" --max-results 5 --allow-open-product-page --allow-cart --allow-precheckout"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@openai/agents": "^0.5.2",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.18.10",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
